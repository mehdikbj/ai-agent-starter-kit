# Copy this file to `.env` and fill in your values.
# The `.env` file is git-ignored and should NEVER be committed.

# ---------------------------------------------------------------------------
# Model Configuration
# ---------------------------------------------------------------------------
# The Ollama model to use. Defaults to llama3.1 if not set.
# Run `ollama list` to see your installed models.
# Browse available models at: https://ollama.com/library
MODEL_ID=llama3.1

# ---------------------------------------------------------------------------
# Ollama Server
# ---------------------------------------------------------------------------
# Only change this if Ollama is running on a different host or port
# (e.g., a remote machine on your local network).
OLLAMA_BASE_URL=http://localhost:11434/v1
